# ============================================================
# .env.example — скопіюй у .env і заповни реальні значення
# Цей файл можна комітити в git. Сам .env — ніколи.
# ============================================================

# --- PostgreSQL ---
POSTGRES_USER=marketplace_user        # Ім'я користувача БД
POSTGRES_PASSWORD=your_strong_password # Пароль БД (мінімум 16 символів у prod)
POSTGRES_DB=marketplace_db             # Назва бази даних

# --- Redis ---
REDIS_PORT=6379                        # Порт Redis (стандартний — 6379)

# --- API ---
API_PORT=4000                          # Порт Express-сервера
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5432/${POSTGRES_DB}?schema=public

# --- JWT (обов'язково змінити перед деплоєм!) ---
# Генерація: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=change_me_to_random_64_char_hex_string
JWT_REFRESH_SECRET=change_me_to_another_random_64_char_hex_string

# --- Cloudinary (фаза 4: фото товарів) ---
# Реєстрація: https://cloudinary.com
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- SendGrid (фаза 4: email-сповіщення) ---
# Реєстрація: https://sendgrid.com
SENDGRID_API_KEY=

# --- LiqPay (фаза 2: оплата, mock у dev) ---
LIQPAY_PUBLIC_KEY=
LIQPAY_PRIVATE_KEY=
